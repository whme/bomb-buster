{
  "name": "Bomb Busters",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/bomb-busters",

  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "moby": false
    }
  },

  "forwardPorts": [5173, 54321, 54323],
  "portsAttributes": {
    "5173":  { "label": "Vite Dev Server" },
    "54321": { "label": "Supabase API" },
    "54323": { "label": "Supabase Studio" }
  },

  "postCreateCommand": "if [ -f package.json ]; then npm install; fi",

  "customizations": {
    "vscode": {
      "extensions": [
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint",
        "bradlc.vscode-tailwindcss",
        "ms-azuretools.vscode-docker",
        "anthropics.claude-code"
      ],
      "settings": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true
      }
    }
  },

  "remoteUser": "node"
}
